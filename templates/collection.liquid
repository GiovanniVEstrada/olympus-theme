<nav class="opl-site-nav">
  <a href="{{ routes.root_url }}" class="opl-site-nav__brand">OLYMPUS PERFORMANCE LABS</a>
  <div class="opl-site-nav__menu">
    <a href="/collections/pre-workout">Shop</a>
    <a href="/pages/about">About</a>
    <a href="/pages/contact">Contact</a>
    <a href="{{ routes.cart_url }}" class="opl-site-nav__cart">Cart <span class="opl-site-nav__cart-count">{{ cart.item_count }}</span></a>
  </div>
</nav>
<div style="padding:60px 36px;max-width:1240px;margin:0 auto;font-family:Georgia,serif;">
  <h1 style="font-size:48px;font-weight:400;margin-bottom:48px;text-align:center;">{{ collection.title }}</h1>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:32px;">
    {% for product in collection.products %}
      <a href="{{ product.url }}" style="display:block;text-decoration:none;color:inherit;border:1px solid #e5ddd0;background:#fff;transition:border-color 0.2s;" onmouseover="this.style.borderColor='#b8923a'" onmouseout="this.style.borderColor='#e5ddd0'">
        {% if product.featured_image %}
          <img src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}" alt="{{ product.title }}" style="width:100%;aspect-ratio:1;object-fit:contain;padding:24px;background:#f5f2ec;">
        {% else %}
          <div style="aspect-ratio:1;background:#f5f2ec;display:flex;align-items:center;justify-content:center;">
            <img src="{{ 'nectar-tub-approved.png' | asset_url }}" alt="{{ product.title }}" style="max-height:240px;object-fit:contain;">
          </div>
        {% endif %}
        <div style="padding:24px;">
          <div style="font-size:22px;margin-bottom:8px;">{{ product.title }}</div>
          <div style="font-size:24px;font-weight:600;">{{ product.price | money }}</div>
        </div>
      </a>
    {% endfor %}
  </div>
</div>
{% section 'opl-footer' %}
