/* ═══════════════════════════════════════════════
   OLYMPUS PERFORMANCE LABS — opl.css.liquid
   White Marble · Gold · Black · Greek Luxury
═══════════════════════════════════════════════ */

:root {
  --opl-bg:     #f5f2ec;
  --opl-white:  #ffffff;
  --opl-black:  #111111;
  --opl-gold:   #b8923a;
  --opl-gold-lt:#d4a94e;
  --opl-text:   #3d3d3d;
  --opl-border: #dccfb6;
  --opl-muted:  rgba(17,17,17,0.6);
}

* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; background: var(--opl-bg); color: var(--opl-black); }
body { font-family: Georgia, "Times New Roman", serif; }
img { max-width: 100%; height: auto; display: block; }
a { text-decoration: none; color: inherit; }
.page-width { max-width: 1240px; margin: 0 auto; padding: 0 36px; }


/* ═══════════════════════════════════════
   HOME HERO
═══════════════════════════════════════ */
.opl-home-hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  text-align: center;
}

@media (min-width: 1024px) {
  .opl-home-hero {
    min-height: 125vh;
  }
}

/* Full-bleed hero image — positioned behind nav and content */

.opl-home-hero__bg {
  position: absolute;
  inset: 0;
  background-repeat: no-repeat;
  background-position: right 20%;
  background-size: cover;
  z-index: 1;
}

.opl-home-hero__bg::after {
  content: "";
  position: absolute;
  inset: 0;

  background: linear-gradient(
    to right,
    rgba(255,255,255,0.10) 0%,
    rgba(255,255,255,0.06) 30%,
    rgba(255,255,255,0.02) 50%,
    rgba(255,255,255,0) 65%
  );
}







/* Hero content — sits below wreath + brand text baked into the photo (~52% down) */
.opl-home-hero__content {
  position: relative;
  z-index: 2;
  max-width: 800px;
  width: 100%;
  padding: 0 20px;
}

.opl-hero__laurel {
  font-size: 2rem;
  margin-bottom: 15px;
  color: #c9a96e;
}


/* Wreath logo */
.opl-home-hero__wreath {
  margin-bottom: 28px;
}
.opl-home-hero__wreath img {
  width: 200px;
  height: auto;
  margin: 0 auto;
  filter: drop-shadow(0 4px 14px rgba(180,140,40,0.28));
}

/* Brand name in gold */
.opl-hero__brand {
  letter-spacing: 3px;
  font-size: 0.8rem;
  text-transform: uppercase;
  color: #6b6b6b;
  margin-bottom: 10px;
}

.opl-hero__sub {
  font-size: 1rem;
  letter-spacing: 2px;
}

/* Main headline */
.opl-home-hero__headline {
  font-size: clamp(42px, 5vw, 72px);
  line-height: 1.1;
  margin: 16px 0;
}

/* Gold product subtitle */
.opl-home-hero__subheadline {
  letter-spacing: 2px;
  font-size: 0.9rem;
  text-transform: uppercase;
  margin-bottom: 10px;
}

/* Italic tagline */
.opl-home-hero__tagline {
  font-family: Georgia, "Times New Roman", serif;
  font-size: clamp(18px, 2.2vw, 26px);
  font-style: italic;
  color: var(--opl-black);
  margin: 0 0 44px;
}

/* CTA button — gold outline, transparent fill */
.opl-home-hero__button {
  display: inline-block;
  margin-top: 20px;
  padding: 14px 32px;
  border: 1px solid #1a1a1a;
  text-decoration: none;
  font-size: 0.95rem;
  letter-spacing: 1px;
  color: #1a1a1a;
  transition: all 0.3s ease;
  z-index: 1;
  position: relative;
}

.opl-home-hero__button::before {
  content: "";
  position: absolute;
  inset: 0;
  background: #c9a96e;
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.35s ease;
  z-index: -1;
}

.opl-home-hero__button:hover::before {
  transform: scaleX(1);
}

.opl-home-hero__button:hover {
  color: #fff;
  border-color: #c9a96e;
}







/* ═══════════════════════════════════════
   PRODUCT PAGE STICKY NAV
═══════════════════════════════════════ */
.opl-site-nav {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 40px;

  background: rgba(245,242,236,0.96);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: border-bottom: 1px solid rgba(184,146,58,0.25);
  box-shadow: 0 1px 0 rgba(255,255,255,0.6) inset;;

}

.opl-site-nav__brand {
  font-family: Georgia, "Times New Roman", serif;
  font-size: 14px;
  letter-spacing: 0.28em;
  color: #2a2a2a;
  text-transform: uppercase;
  text-decoration: none;
  transition: color 0.2s;
}
.opl-site-nav__brand:hover { color: var(--opl-gold); }


.opl-site-nav__menu { display: flex; gap: 30px; align-items: center; }
.opl-site-nav__menu a {
  font-family: Georgia, "Times New Roman", serif;
  font-size: 16px;
  color: var(--opl-black);
  transition: color 0.2s;
  border-bottom: 1px solid rgba(184,146,58,0.25);
box-shadow: 0 1px 0 rgba(255,255,255,0.6) inset;
}

.opl-site-nav__menu a:hover { color: var(--opl-gold); }
.opl-site-nav__cart {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 15px;
}



.opl-site-nav__cart-count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 18px; height: 18px;
  border-radius: 50%;
  background: rgba(184,146,58,0.12);
  border: 1px solid rgba(184,146,58,0.3);
  font-size: 10px;
  color: var(--opl-gold);
}

/* NAV BAR FOR HOME PAGE */
.opl-nav__brand {
  font-size: 0.9rem;
  letter-spacing: 2px;
}
.opl-nav__menu { display: flex; gap: 36px; }
.opl-nav__menu a {
  margin-left: 20px;
  text-decoration: none;
  color: #1a1a1a;
  font-size: 0.9rem;
}
.opl-nav__menu a:hover { color: var(--opl-gold); }
.opl-site-nav::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 1px;

  background: linear-gradient(
    to right,
    transparent,
    rgba(201,169,110,0.6),
    transparent
  );

  opacity: 0.6;
}

/* Nav bar + centered on phone */
.opl-nav {
  position: absolute;
  top: 0;
  width: 100%;
  z-index: 3;
  display: flex;
  justify-content: space-between;
  padding: 20px 40px;
  border-bottom: 1px solid rgba(0, 0, 0, 0.25);
  box-shadow: 0 1px 0 rgba(255,255,255,0.6) inset;
  
}

@media (max-width: 768px) {
  .opl-nav {
    flex-direction: column;
    align-items: center;
    padding: 16px 20px;
    gap: 10px;
  }

  .opl-nav__menu {
    justify-content: center;
    gap: 20px;
  }

  .opl-nav__menu a {
    margin-left: 0;
  }
}



/* ═══════════════════════════════════════
   PRODUCT HERO
═══════════════════════════════════════ */
.opl-product-hero { padding: 72px 24px 36px; }
.opl-product-hero__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
}
.opl-product-hero__image {
  display: block;
  max-width: 520px;
  width: 100%;
  margin: 0 auto;
}
.opl-product-hero__eyebrow {
  color: var(--opl-gold);
  font-size: 14px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  margin-bottom: 10px;
}
.opl-product-hero__title {
  font-size: 58px;
  line-height: 1.05;
  margin: 0 0 8px;
}
.opl-product-hero__subtitle {
  color: var(--opl-gold);
  font-size: 32px;
  margin-bottom: 16px;
}
.opl-product-hero__flavor {
  font-size: 22px;
  margin-bottom: 18px;
}
.opl-product-hero__description {
  font-size: 20px;
  line-height: 1.6;
  color: var(--opl-text);
  margin-bottom: 20px;
}
.opl-product-hero__price {
  font-size: 46px;
  font-weight: 700;
  margin-bottom: 18px;
}
.opl-product-hero__offer {
  border: 1px solid var(--opl-border);
  padding: 16px 20px;
  color: var(--opl-gold);
  font-size: 17px;
  letter-spacing: 0.06em;
  margin-bottom: 16px;
  line-height: 1.6;
}
.opl-product-hero__meta {
  font-size: 19px;
  color: var(--opl-text);
  margin-bottom: 10px;
}
.opl-product-hero__button {
  margin-top: 10px;
  display: inline-block;
  background: #111111;
  color: #ffffff;
  border: none;
  padding: 18px 36px;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 20px;
  cursor: pointer;
  transition: background 0.25s;
  letter-spacing: 0.06em;
}
.opl-product-hero__button:hover { background: var(--opl-gold); }
.opl-product-hero__button:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}


/* ═══════════════════════════════════════
   DIFFERENTIATORS
═══════════════════════════════════════ */
.opl-section-title {
  font-family: Georgia, "Times New Roman", serif;
  font-size: 50px;
  text-align: center;
  margin: 0 0 36px;
  font-weight: 400;
}
.opl-section-title--left { text-align: left; }
.opl-diffs { padding: 72px 24px 72px; background: var(--opl-white); }
.opl-diffs__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
.opl-diff-card {
  background: rgba(255,255,255,0.7);
  border: 1px solid rgba(184,146,58,0.25);
  padding: 28px;
}
.opl-diff-card h3 {
  margin: 0 0 14px;
  font-size: 26px;
  font-weight: 400;
  line-height: 1.25;
}
.opl-diff-card p {
  margin: 0;
  font-size: 18px;
  line-height: 1.65;
  color: var(--opl-text);
}


/* ═══════════════════════════════════════
   FORMULA
═══════════════════════════════════════ */
.opl-formula { padding: 72px 24px 90px; background: var(--opl-bg); }
.opl-formula__grid {
  display: grid;
  grid-template-columns: 0.95fr 1.05fr;
  gap: 52px;
}
.opl-formula__callout { margin-bottom: 32px; }
.opl-formula__callout h3 {
  margin: 0 0 10px;
  font-size: 30px;
  font-weight: 400;
}
.opl-formula__callout p {
  margin: 0;
  font-size: 19px;
  line-height: 1.7;
  color: var(--opl-text);
}
.opl-formula__group { margin-bottom: 28px; }
.opl-formula__group h4 {
  margin: 0 0 10px;
  color: var(--opl-gold);
  font-size: 26px;
  font-weight: 400;
}
.opl-formula__group ul {
  list-style: none;
  margin: 0; padding: 0;
  border-top: 1px solid rgba(0,0,0,0.08);
}
.opl-formula__group li {
  display: flex;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid rgba(0,0,0,0.08);
  font-size: 18px;
  color: var(--opl-text);
}
.opl-formula__group .amount {
  margin-left: auto;
  white-space: nowrap;
}


/* ═══════════════════════════════════════
   FOOTER
═══════════════════════════════════════ */
.opl-footer {
  display: grid;
  grid-template-columns: 72px 1fr;
  gap: 40px;
  padding: 80px 40px 50px;
  background: #f8f6f2; 
  border-top: 1px solid rgba(184,146,58,0.15);
}
.opl-footer__logo img { 
  width: 54px;
  opacity: 0.9;
}
.opl-footer__content  {
  display: flex;
  flex-direction: column;
  gap: 40px;
}

.footer-info h2 {
  font-size: 26px;
  font-weight: 500;
  line-height: 1.5;
  max-width: 720px;
  color: #1a1a1a;
}

.footer-actions {
  display: flex;
  gap: 80px;
}

.footer-actions > div {
  min-width: 140px;
}


.action-header {
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 14px;
  color: #1a1a1a;
}

.unordered-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.unordered-list li { margin-bottom: 8px; }

.unordered-list a {
  font-size: 15px;
  color: #5f5f5f;
  text-decoration: none;
  transition: all 0.25s ease;
}
 
.unordered-list a {
  position: relative;
}

.unordered-list a::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -2px;
  width: 0;
  height: 1px;
  background: #b8923a;
  transition: width 0.3s ease;
}

.unordered-list a:hover::after {
  width: 100%;
}

.unordered-list a:hover {
  color: #b8923a; 
}

.social-icons {
  display: flex;
  gap: 14px;
  margin-top: 20px;
}

.social-icons img {
  width: 20px;
  height: 20px;
  opacity: 0.7;
  transition: all 0.3s ease;
}

.social-icons a:hover img {
  opacity: 1;
  transform: translateY(-2px);
}

.copyright {
  margin-top: 10px;
  font-size: 14px;
  color: #8a8a8a;
}
.opl-footer__links a:hover { color: var(--opl-gold); }


/* ═══════════════════════════════════════
   SIMPLE PAGES (About, Contact)
═══════════════════════════════════════ */
.opl-simple-page { padding: 90px 24px; }
.opl-simple-page h1 { font-size: 52px; margin: 0 0 20px; font-weight: 400; }
.opl-simple-page p,
.opl-simple-page .rte {
  max-width: 800px;
  font-size: 21px;
  line-height: 1.75;
  color: var(--opl-text);
}


/* ═══════════════════════════════════════
   MOBILE
═══════════════════════════════════════ */
@media (max-width: 989px) {
  .opl-home-hero__bg-img {
    object-position: 60% top;
  }
  .opl-nav {
    flex-direction: column;
    gap: 14px;
    padding: 20px 24px;
  }
  .opl-nav__menu { gap: 20px; }
  .opl-site-nav {
    flex-direction: column;
    gap: 12px;
    padding: 16px 20px;
  }
  .opl-site-nav__menu { gap: 16px; flex-wrap: wrap; justify-content: center; }
  .opl-product-hero__grid,
  .opl-diffs__grid,
  .opl-formula__grid,
  .opl-footer { grid-template-columns: 1fr; }
  .opl-home-hero__content { padding-top: 60px; padding-bottom: 100px; }
  .opl-home-hero__headline { font-size: clamp(36px, 9vw, 60px); }
  .opl-product-hero__title { font-size: 40px; }
  .opl-section-title { font-size: 34px; }
  .opl-home-hero__wreath img { width: 120px; }
}

@media (max-width: 600px) {
  .opl-nav { padding: 16px 20px; }
  .opl-home-hero__content { padding-top: 40px; padding-bottom: 80px; }
  .opl-home-hero__button { padding: 16px 36px; font-size: 14px; }
  .opl-product-hero { padding: 48px 20px 24px; }
}
