<section class="opl-formula page-width">
  <div class="opl-formula__grid">
    <div class="opl-formula__left">
      <h2 class="opl-section-title opl-section-title--left">Full Transparent Formula</h2>

      <div class="opl-formula__callout">
        <h3>Energy</h3>
        <p>200mg caffeine paired with theobromine for smooth sustained energy.</p>
      </div>

      <div class="opl-formula__callout">
       
        <p>No proprietary blends. Fully transparent ingredients built for performance, focus, and energy.</p>
      </div>

      <div class="opl-formula__callout">
        <h3>Powerful Absorption with AstraGin®</h3>
        <p>Patented AstraGin® supports absorption to help maximize ingredient efficacy.</p>
      </div>
    </div>

    <div class="opl-formula__right">
      <div class="opl-formula__group">
        <h4>Performance</h4>
        <ul>
          <li>
            <span>L-Citrulline</span>
            <span class="amount">4g</span>
          </li>
          <li>
            <span>Beta-Alanine</span>
            <span class="amount">3.2g</span> 
          </li>
          <li>
            <span>Betaine Anhydrous</span>
            <span class="amount">2.5g</span> 
          </li>
          <li>
            <span>Taurine</span>
            <span class="amount">2g</span> 
          </li>
          <li>
            <span>Nitrosigine®</span>
            <span class="amount">1.5g</span>
          </li>
        </ul>
      </div>

      <div class="opl-formula__group">
        <h4>Focus</h4>
        <ul>
          <li>
            <span>L-Theanine</span>
            <span class="amount">200mgs</span> 
          </li>
          <li>Acetyl-L-Carnitine </li>
          <li>
            <span>L-Tyrosine</span>
            <span class="amount">1g</span> 
          </li>
          <li>
            <span>Alpha-GPC 50%</span>
            <span class="amount">300mgs</span> </li>
          <li>
            <span>Huperzine A</span>
            <span class="amount">100mcg</span> 
          </li>
        </ul>
      </div>

      <div class="opl-formula__group">
        <h4>Energy</h4>
        <ul>
          <li>
            <span>Caffeine Anhydrous</span>
            <span class="amount">200mgs</span> 
          </li>
          <li>
            <span>Theobromine</span>
            <span class="amount">100mgs</span> 
          </li>
        </ul>
      </div>

      <div class="opl-formula__group">
        <h4>Absorption</h4>
        <ul>
          <li>
            <span>AstraGin®</span>
            <span class="amount">25mgs</span> 
          </li>
        </ul>
      </div>

      <div class="opl-formula__group">
        <h4>Support</h4>
        <ul>
          <li>Electrolytes</li>
          <li>
            <span>Pink Salt</span>
            <span class="amount">500mgs</span> 
          </li>
          <li>
            <span>Vitamin D3</span>
            <span class="amount">1,000ius</span> 
          </li>
          <li>Niacin</li>
          <li>Vitamin B6</li>
          <li>Vitamin B12</li>
        </ul>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "OPL Formula",
  "settings": [],
  "presets": [{ "name": "OPL Formula" }]
}
{% endschema %}
